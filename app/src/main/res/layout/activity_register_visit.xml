<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:orientation="vertical"
    tools:context=".visits.RegisterVisitActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Registrar visita"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== FORMULARIO ===== -->
            <LinearLayout
                android:id="@+id/formContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Datos del visitante"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp"
                    android:text="Se generará un código QR único para esta visita."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Tipo de visita"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipFamiliar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_selected"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:text="Familiar"
                            android:textColor="@color/white"
                            android:textSize="13.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipDelivery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:text="Delivery"
                            android:textColor="@color/text_secondary"
                            android:textSize="13.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipProveedor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:text="Proveedor"
                            android:textColor="@color/text_secondary"
                            android:textSize="13.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chipOtro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="10dp"
                            android:text="Otro"
                            android:textColor="@color/text_secondary"
                            android:textSize="13.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </HorizontalScrollView>

                <EditText
                    android:id="@+id/etVisitorName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Nombre completo"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="textPersonName" />

                <EditText
                    android:id="@+id/etVisitorDocument"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="RUT / DNI"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="text" />

                <EditText
                    android:id="@+id/etVisitDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Fecha de la visita"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true" />

                <EditText
                    android:id="@+id/etApartment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_input"
                    android:hint="Departamento que visita"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="text" />

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text=""
                    android:textColor="#FF6B6B"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnGenerateQr"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Generar código QR"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ===== RESULTADO: QR GENERADO ===== -->
            <LinearLayout
                android:id="@+id/resultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="12dp"
                    android:background="@drawable/bg_pill_active"
                    android:src="@drawable/ic_shield_check"
                    android:contentDescription="Visita creada" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="¡Visita registrada!"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvResultSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Comparte este código con tu visita para que lo presente en el portón."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_card"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgQrCode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Código QR de la visita" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvQrId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="monospace"
                    android:text=""
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnShareQr"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_outline"
                    android:text="Compartir código"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_purple_light"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnNewVisit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Registrar otra visita"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
