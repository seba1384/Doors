<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:orientation="vertical"
    tools:context=".visits.RegisterVisitActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_header_gradient"
        android:paddingHorizontal="12dp"
        android:paddingTop="28dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Registrar visita"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== FORMULARIO ===== -->
            <LinearLayout
                android:id="@+id/formContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Datos del visitante"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="14dp"
                    android:text="Se generará un código QR único para esta visita."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Tipo de visita"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipFamiliar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_selected"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:text="Familiar o amigo"
                            android:textColor="@color/white"
                            android:textSize="13.5sp"
                            android:textStyle="bold"
                            android:drawableStart="@drawable/ic_users"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical" />

                        <TextView
                            android:id="@+id/chipDelivery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:text="Delivery"
                            android:textColor="@color/text_secondary"
                            android:textSize="13.5sp"
                            android:textStyle="bold"
                            android:drawableStart="@drawable/ic_visit_delivery"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical" />

                        <TextView
                            android:id="@+id/chipProveedor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:text="Proveedor"
                            android:textColor="@color/text_secondary"
                            android:textSize="13.5sp"
                            android:textStyle="bold"
                            android:drawableStart="@drawable/ic_visit_provider"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical" />

                        <TextView
                            android:id="@+id/chipOtro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:text="Otro"
                            android:textColor="@color/text_secondary"
                            android:textSize="13.5sp"
                            android:textStyle="bold"
                            android:drawableStart="@drawable/ic_visit_other"
                            android:drawablePadding="8dp"
                            android:gravity="center_vertical" />
                    </LinearLayout>
                </HorizontalScrollView>

                <EditText
                    android:id="@+id/etVisitorName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Nombre completo"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="textPersonName" />

                <EditText
                    android:id="@+id/etVisitorDocument"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="RUT / DNI"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp"
                    android:text="Instancia de la visita"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etVisitDateFrom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Desde (fecha y hora)"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true" />

                <EditText
                    android:id="@+id/etVisitDateTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Hasta (fecha y hora)"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="El código QR dejará de funcionar automáticamente al término de esta ventana."
                    android:textColor="@color/text_muted"
                    android:textSize="11.5sp" />

                <EditText
                    android:id="@+id/etApartment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Departamento que visita"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="false" />

                <EditText
                    android:id="@+id/etVehicle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_input"
                    android:hint="Vehículo (opcional)"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="textCapCharacters" />

                <EditText
                    android:id="@+id/etReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_input"
                    android:hint="Motivo de la visita (opcional)"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:padding="16dp"
                    android:inputType="text" />

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text=""
                    android:textColor="#FF6B6B"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnGenerateQr"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Generar código QR"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ===== RESULTADO: QR GENERADO ===== -->
            <LinearLayout
                android:id="@+id/resultContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="12dp"
                    android:background="@drawable/bg_pill_active"
                    android:src="@drawable/ic_shield_check"
                    android:contentDescription="Visita creada" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="¡Código QR generado con éxito!"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvResultSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Comparte este código con tu visita para que pueda ingresar al condominio."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <FrameLayout
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_card"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgQrCode"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Código QR de la visita" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvQrId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="monospace"
                    android:text=""
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <!-- ===== DETALLES DE LA VISITA ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="Detalles de la visita"
                        android:textColor="@color/text_primary"
                        android:textSize="14.5sp"
                        android:textStyle="bold" />

                    <LinearLayout style="@style/DetailRow">
                        <TextView style="@style/DetailLabel" android:text="Visitante" />
                        <TextView android:id="@+id/tvDetailVisitor" style="@style/DetailValue" tools:text="Juan Pérez" />
                    </LinearLayout>

                    <LinearLayout style="@style/DetailRow">
                        <TextView style="@style/DetailLabel" android:text="Tipo de visita" />
                        <TextView android:id="@+id/tvDetailType" style="@style/DetailValue" tools:text="Familiar o amigo" />
                    </LinearLayout>

                    <LinearLayout style="@style/DetailRow">
                        <TextView style="@style/DetailLabel" android:text="Desde" />
                        <TextView android:id="@+id/tvDetailFrom" style="@style/DetailValue" tools:text="18/05/2026 14:00" />
                    </LinearLayout>

                    <LinearLayout style="@style/DetailRow">
                        <TextView style="@style/DetailLabel" android:text="Hasta" />
                        <TextView android:id="@+id/tvDetailTo" style="@style/DetailValue" tools:text="18/05/2026 18:00" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowDetailVehicle"
                        style="@style/DetailRow">
                        <TextView style="@style/DetailLabel" android:text="Vehículo" />
                        <TextView android:id="@+id/tvDetailVehicle" style="@style/DetailValue" tools:text="ABC123" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowDetailReason"
                        style="@style/DetailRow">
                        <TextView style="@style/DetailLabel" android:text="Motivo" />
                        <TextView android:id="@+id/tvDetailReason" style="@style/DetailValue" tools:text="Reunión familiar" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== VIGENCIA DEL CODIGO ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_pill_active"
                    android:padding="12dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_green" />

                    <TextView
                        android:id="@+id/tvExpiryInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Código vigente. Expirará el 18/05/2026 a las 18:00."
                        android:textColor="@color/success_green"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- ===== NOTAS IMPORTANTES ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_result_info"
                            android:contentDescription="" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Notas importantes"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="•  Comparte el código QR solo con tu visita."
                        android:textColor="@color/text_secondary"
                        android:textSize="12.5sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="•  El código expirará automáticamente al finalizar el tiempo establecido."
                        android:textColor="@color/text_secondary"
                        android:textSize="12.5sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="•  El código permite 2 escaneos: uno para entrar y otro para salir del condominio."
                        android:textColor="@color/text_secondary"
                        android:textSize="12.5sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnShareQr"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_button_outline"
                    android:text="Compartir código"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_purple_light"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnNewVisit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Registrar otra visita"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
