<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp">

    <ImageView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="14dp"
        android:background="@drawable/bg_icon_circle"
        android:src="@drawable/ic_shield_check"
        android:contentDescription="Panel de administración" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Panel de administración"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Ingresa el PIN de acceso para continuar."
        android:textColor="@color/text_secondary"
        android:textSize="13.5sp" />

    <EditText
        android:id="@+id/etPin"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_input"
        android:gravity="center"
        android:hint="••••"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:padding="16dp"
        android:letterSpacing="0.5"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvPinError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="PIN incorrecto. Inténtalo de nuevo."
        android:textColor="#FF6B6B"
        android:textSize="12.5sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnPinCancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_outline"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="@color/brand_purple_light"
            android:textSize="14.5sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPinConfirm"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_button_primary"
            android:text="Ingresar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="14.5sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
